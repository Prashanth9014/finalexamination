{
  "name": "online-recruit-system-backend",
  "version": "1.0.0",
  "description": "Backend for Online Recruitment Process – Online Examination System",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:ci": "jest tests/unit/utils --passWithNoTests",
    "lint": "echo \"No linter configured yet\"",
    "kill-port": "npx kill-port 5000",
    "cleanup-submissions": "ts-node scripts/cleanupSubmissions.ts"
  },
  "keywords": [],
